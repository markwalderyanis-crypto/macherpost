# env.patch — MacherPost Local-Only Refactor (2026-04-15)
#
# Wende diesen Patch auf /var/www/macherpost/.env an:
# - Entferne die obsoleten Cloud-Provider-Keys
# - Fuege die lokalen Endpunkte hinzu
# - Setze ggf. PIPELINE_SCHEDULER=off zum Deaktivieren des Cron-Schedulers
#
# Beispiel (manuell):
#   nano /var/www/macherpost/.env
#   # Zeilen mit ANTHROPIC_API_KEY, KIMI_API_KEY, GEMINI_API_KEY,
#   # OPENAI_API_KEY, STABILITY_API_KEY, SERPAPI_KEY, NANOBANANA_API_KEY,
#   # TEXT_PROVIDER, IMAGE_PROVIDER  loeschen
#   # Den Block unten anhaengen
#   pm2 restart macherpost

--- ENTFERNEN -----------------------------------------------------
ANTHROPIC_API_KEY=...
KIMI_API_KEY=...
KIMI_BASE_URL=...
KIMI_MODEL=...
GEMINI_API_KEY=...
GEMINI_MODEL=...
OPENAI_API_KEY=...
STABILITY_API_KEY=...
SERPAPI_KEY=...
NANOBANANA_API_KEY=...
NANOBANANA_BASE_URL=...
TEXT_PROVIDER=claude
IMAGE_PROVIDER=stability

--- HINZUFUEGEN ---------------------------------------------------
# Lokale KI-Endpunkte (vom PC via SSH Reverse Tunnel)
# Tunnel-Befehl auf dem PC:
#   ssh -N -R 5577:localhost:5577 -R 5578:localhost:5578 root@macherpost.com
LOCAL_TEXT_URL=http://localhost:5578
LOCAL_TEXT_MODEL=gemma3:12b
LOCAL_TEXT_MAX_TOKENS=8192
LOCAL_IMAGE_URL=http://localhost:5577
LOCAL_IMAGE_TOKEN=mpost-img-2026

# Optional: Pipeline-Scheduler explizit ausschalten (z.B. fuer Wartung)
# PIPELINE_SCHEDULER=off
