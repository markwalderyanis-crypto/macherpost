<!DOCTYPE html>
<html lang="de">
<head>
    <%- include('partials/head') %>
    <title><%= pdf.title %> — MacherPost</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.min.mjs" type="module"></script>
    <style>
        .article-wrapper { max-width: 780px; margin: 0 auto; padding: 0 20px; }

        /* ── MacherPost Header ── */
        .mp-article-header {
            display: flex; justify-content: space-between; align-items: center;
            padding: 20px 0; border-bottom: 3px solid #F97316; margin-bottom: 32px;
        }
        .mp-logo { font-family: Georgia, 'Times New Roman', serif; font-size: 26px; font-weight: 800; letter-spacing: -0.5px; }
        .mp-logo-macher { color: #1a1a1e; }
        .mp-logo-post { color: #F97316; }
        .mp-theme-name { font-size: 14px; font-weight: 700; color: #F97316; text-transform: uppercase; letter-spacing: 1px; }

        /* ── Rating ── */
        .rating-section { margin: 32px 0; padding: 24px; background: var(--c-section-alt); border-radius: var(--radius); }
        .star-rating { display: inline-flex; gap: 2px; }
        .star-rating .star { font-size: 28px; cursor: pointer; color: #D1D5DB; transition: color 0.15s; user-select: none; }
        .star-rating .star:hover, .star-rating .star.hovered { color: #F59E0B; }
        .star-rating .star.active { color: #F59E0B; }
        .rating-avg { display: inline-flex; align-items: center; gap: 6px; font-size: 14px; color: var(--c-muted); }
        .rating-avg .stars-filled { color: #F59E0B; font-size: 16px; letter-spacing: 1px; }

        /* ── PDF pages ── */
        .pdf-page-container { margin: 32px 0; }
        .pdf-page { width: 100%; margin-bottom: 2px; display: block; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }

        /* ── MacherPost Footer ── */
        .mp-article-footer {
            margin-top: 48px; padding: 24px 0; border-top: 3px solid #F97316;
            display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;
        }
        .mp-footer-left { font-size: 12px; color: var(--c-dark); }
        .mp-footer-url { font-size: 13px; font-weight: 700; color: #F97316; text-decoration: none; }
        .mp-footer-url:hover { text-decoration: underline; }
        .mp-footer-disclaimer { font-size: 11px; color: var(--c-muted); text-align: center; margin-top: 12px; width: 100%; }
    </style>
</head>
<body>
<%- include('partials/nav') %>

<main class="content" style="margin: 40px auto;">
    <div class="article-wrapper">

        <!-- ═══ MACHERPOST HEADER ═══ -->
        <div class="mp-article-header">
            <div class="mp-logo">
                <span class="mp-logo-macher">Macher</span><span class="mp-logo-post">Post</span>
            </div>
            <div class="mp-theme-name"><%= themeName %></div>
        </div>

        <a href="/archiv/<%= pdf.theme_slug %>" style="font-size: 13px; color: var(--c-muted); text-decoration: none;">&larr; Zur&uuml;ck zu <%= themeName %></a>

        <div style="margin-top: 20px;">
            <div style="font-size: 13px; color: var(--c-muted); display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
                <span><%= new Date(pdf.publish_date).toLocaleDateString('de-CH', { day: 'numeric', month: 'long', year: 'numeric' }) %></span>
                <% if (typeof readingMin !== 'undefined' && readingMin > 0) { %>
                    <span>&bull;</span>
                    <span>~<%= readingMin %> Min. Lesezeit</span>
                <% } %>
                <% if (ratingCount > 0) { %>
                    <span>&bull;</span>
                    <span class="rating-avg">
                        <span class="stars-filled"><% for (let i = 1; i <= 5; i++) { %><%= i <= Math.round(avgRating) ? '\u2605' : '\u2606' %><% } %></span>
                        <span><%= avgRating %> (<%= ratingCount %>)</span>
                    </span>
                <% } %>
            </div>

            <h1 style="font-size: 32px; font-weight: 800; line-height: 1.25; margin: 12px 0 0;"><%= pdf.title %></h1>
        </div>

        <div style="display:flex; gap:12px; margin:24px 0 32px; align-items:center; flex-wrap:wrap;">
            <% if (pdf.html_content) { %>
                <a href="/artikel/<%= pdf.id %>/web" class="btn btn-sm btn-primary" style="font-size:13px;">Textansicht</a>
            <% } %>
            <a href="/pdf/<%= pdf.id %>/download" class="btn btn-sm btn-outline" style="font-size:13px;">&#8681; PDF herunterladen</a>
        </div>

        <!-- PDF pages rendered by pdf.js -->
        <div class="pdf-page-container" id="pdf-container">
            <div style="text-align: center; padding: 48px; color: var(--c-muted);">
                <p>PDF wird geladen...</p>
            </div>
        </div>

        <div style="text-align: center; margin-bottom: 32px;">
            <a href="/pdf/<%= pdf.id %>/download" class="btn btn-outline btn-sm" style="font-size:13px;">&#8681; PDF herunterladen</a>
        </div>

        <!-- ═══ MACHERPOST FOOTER ═══ -->
        <div class="mp-article-footer">
            <div class="mp-footer-left">
                <span class="mp-logo" style="font-size: 18px;">
                    <span class="mp-logo-macher">Macher</span><span class="mp-logo-post">Post</span>
                </span>
            </div>
            <a href="https://macherpost.com" class="mp-footer-url">www.macherpost.com</a>
            <div class="mp-footer-disclaimer">
                Dieser Bericht wurde mit Unterst&uuml;tzung von KI erstellt und redaktionell gepr&uuml;ft.
            </div>
        </div>

        <!-- ═══ RATING ═══ -->
        <% if (user) { %>
        <div class="rating-section">
            <h3 style="margin: 0 0 16px; font-size: 16px; font-weight: 700;">Wie hat dir dieser Beitrag gefallen?</h3>
            <form method="POST" action="/api/rate" id="rating-form">
                <input type="hidden" name="pdf_id" value="<%= pdf.id %>">
                <input type="hidden" name="stars" id="rating-value" value="<%= userRating %>">
                <div class="star-rating" id="star-rating">
                    <% for (let i = 1; i <= 5; i++) { %>
                        <span class="star <%= i <= userRating ? 'active' : '' %>" data-value="<%= i %>">&#9733;</span>
                    <% } %>
                </div>
                <button type="submit" class="btn btn-primary btn-sm" style="margin-top: 12px;">Bewerten</button>
                <% if (userRating > 0) { %>
                    <span style="font-size: 13px; color: var(--c-muted); margin-left: 12px;">Du hast <%= userRating %> Stern<%= userRating > 1 ? 'e' : '' %> gegeben</span>
                <% } %>
            </form>
        </div>
        <% } %>

        <!-- ═══ COMMENTS ═══ -->
        <%- include('partials/comments') %>

    </div>
</main>

<%- include('partials/footer') %>

<script type="module">
  const pdfjsLib = await import('https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.min.mjs');
  pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.worker.min.mjs';

  const container = document.getElementById('pdf-container');
  try {
    const pdf = await pdfjsLib.getDocument('/pdf/<%= pdf.id %>/view').promise;
    container.innerHTML = '';
    for (let i = 1; i <= pdf.numPages; i++) {
      const page = await pdf.getPage(i);
      const scale = (container.clientWidth) / page.getViewport({ scale: 1 }).width;
      const viewport = page.getViewport({ scale });
      const canvas = document.createElement('canvas');
      canvas.className = 'pdf-page';
      canvas.width = viewport.width;
      canvas.height = viewport.height;
      canvas.style.width = '100%';
      canvas.style.height = 'auto';
      container.appendChild(canvas);
      await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;
    }
  } catch (e) {
    container.innerHTML = '<div style="text-align:center;padding:48px;color:var(--c-muted);">' +
      '<p>PDF konnte nicht geladen werden.</p>' +
      '<a href="/pdf/<%= pdf.id %>/download" class="btn btn-primary btn-sm">PDF herunterladen</a></div>';
  }
</script>

<script>
// Star rating interaction
const stars = document.querySelectorAll('#star-rating .star');
const ratingInput = document.getElementById('rating-value');

if (stars.length) {
    stars.forEach(star => {
        star.addEventListener('mouseenter', () => {
            const val = parseInt(star.dataset.value);
            stars.forEach(s => {
                s.classList.toggle('hovered', parseInt(s.dataset.value) <= val);
            });
        });

        star.addEventListener('click', () => {
            const val = parseInt(star.dataset.value);
            ratingInput.value = val;
            stars.forEach(s => {
                s.classList.toggle('active', parseInt(s.dataset.value) <= val);
            });
        });
    });

    document.getElementById('star-rating').addEventListener('mouseleave', () => {
        const current = parseInt(ratingInput.value) || 0;
        stars.forEach(s => {
            s.classList.remove('hovered');
            s.classList.toggle('active', parseInt(s.dataset.value) <= current);
        });
    });
}
</script>
</body>
</html>
