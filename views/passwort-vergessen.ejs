<!DOCTYPE html>
<html lang="de">
<head>
    <%- include('partials/head') %>
    <title>Passwort vergessen — MacherPost</title>
</head>
<body>
<%- include('partials/nav') %>

<main class="content" style="max-width: 440px;">
    <h1 style="text-align: center;">Passwort vergessen</h1>

    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (success) { %>
        <div class="alert" style="background: #e8f5e9; color: #2e7d32; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px;"><%= success %></div>
    <% } %>

    <p style="text-align: center; color: var(--c-muted); margin-bottom: 24px; font-size: 14px;">
        Gib deine E-Mail-Adresse ein und wir senden dir einen Link zum Zurücksetzen deines Passworts.
    </p>

    <form method="POST" action="/passwort-vergessen">
        <div class="form-group">
            <label for="email">E-Mail</label>
            <input type="email" id="email" name="email" required placeholder="deine@email.de">
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%;">Link senden</button>
    </form>

    <p style="text-align: center; margin-top: 24px; font-size: 14px; color: var(--c-muted);">
        <a href="/login">Zurück zur Anmeldung</a>
    </p>
</main>

<%- include('partials/footer') %>
</body>
</html>
