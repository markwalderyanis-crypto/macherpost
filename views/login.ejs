<!DOCTYPE html>
<html lang="de">
<head>
    <%- include('partials/head') %>
    <title>Anmelden — MacherPost</title>
</head>
<body>
<%- include('partials/nav') %>

<main class="content" style="max-width: 440px;">
    <h1 style="text-align: center;">Anmelden</h1>

    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert" style="background: #e8f5e9; color: #2e7d32; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px;"><%= success %></div>
    <% } %>

    <% if (typeof googleEnabled !== 'undefined' && googleEnabled) { %>
    <div class="oauth-btns">
        <a href="/auth/google" class="oauth-btn">
            <svg viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Mit Google anmelden
        </a>
        <% if (typeof appleEnabled !== 'undefined' && appleEnabled) { %>
        <a href="/auth/apple" class="oauth-btn">
            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.4C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
            Mit Apple anmelden
        </a>
        <% } %>
    </div>
    <div class="divider"><span>oder per E-Mail</span></div>
    <% } %>

    <form method="POST" action="/login">
        <div class="form-group">
            <label for="email">E-Mail</label>
            <input type="email" id="email" name="email" required placeholder="deine@email.de">
        </div>
        <div class="form-group">
            <label for="password">Passwort</label>
            <input type="password" id="password" name="password" required placeholder="Dein Passwort">
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%;">Anmelden</button>
    </form>

    <p style="text-align: center; margin-top: 12px; font-size: 14px;">
        <a href="/passwort-vergessen" style="color: var(--c-accent);">Passwort vergessen?</a>
    </p>

    <p style="text-align: center; margin-top: 12px; font-size: 14px; color: var(--c-muted);">
        Noch kein Konto? <a href="/register">Jetzt registrieren</a>
    </p>
</main>

<%- include('partials/footer') %>
</body>
</html>
