<!DOCTYPE html>
<html lang="de">
<head>
    <%- include('partials/head') %>
    <title>Warenkorb — MacherPost</title>
</head>
<body>
<%- include('partials/nav') %>

<main class="content">
    <h1>Warenkorb</h1>

    <% if (items.length === 0) { %>
        <div class="card" style="text-align: center; padding: 48px;">
            <p style="font-size: 48px; margin-bottom: 16px;">&#128722;</p>
            <h2 style="margin: 0 0 8px;">Dein Warenkorb ist leer</h2>
            <p style="color: var(--c-muted); margin-bottom: 20px;">Entdecke unsere Pakete und Themen.</p>
            <a href="/" class="btn btn-primary">Zur Startseite</a>
        </div>
    <% } else { %>
        <div style="display: flex; flex-direction: column; gap: 16px; margin-top: 24px;">
            <% let totalMonthly = 0; let totalYearly = 0; %>
            <% for (const item of items) { %>
                <% totalMonthly += item.price_monthly; totalYearly += item.price_yearly; %>
                <div class="card" style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <h3 style="font-size: 16px; font-weight: 700; color: var(--c-dark);"><%= item.name %></h3>
                        <p style="font-size: 13px; color: var(--c-muted); margin: 4px 0 0;">
                            <%= item.type === 'package' ? 'Paket' : 'Einzelthema' %> &bull;
                            CHF <%= (item.price_monthly / 100).toFixed(2) %>/Mt.
                        </p>
                    </div>
                    <form method="POST" action="/warenkorb/remove">
                        <input type="hidden" name="slug" value="<%= item.slug %>">
                        <button type="submit" class="btn btn-outline btn-sm">Entfernen</button>
                    </form>
                </div>
            <% } %>
        </div>

        <div class="card" style="margin-top: 32px; padding: 32px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
                <span style="font-size: 18px; font-weight: 700; color: var(--c-dark);">Total</span>
                <div style="text-align: right;">
                    <div style="font-size: 24px; font-weight: 800; color: var(--c-dark);">CHF <%= (totalMonthly / 100).toFixed(2) %> <small style="font-size: 14px; color: var(--c-muted); font-weight: 500;">/Mt.</small></div>
                    <div style="font-size: 13px; color: var(--c-muted);">oder CHF <%= (totalYearly / 100).toFixed(2) %> /Jahr</div>
                </div>
            </div>

            <% if (user) { %>
            <div style="display: flex; gap: 12px; flex-wrap: wrap;">
                <form method="POST" action="/api/checkout" style="flex: 1;">
                    <input type="hidden" name="interval" value="monthly">
                    <button type="submit" class="btn btn-primary" style="width: 100%;">Monatlich abonnieren</button>
                </form>
                <form method="POST" action="/api/checkout" style="flex: 1;">
                    <input type="hidden" name="interval" value="yearly">
                    <button type="submit" class="btn btn-outline" style="width: 100%;">J&auml;hrlich abonnieren (spare 2 Mt.)</button>
                </form>
            </div>
            <% } else { %>
            <a href="/login" class="btn btn-primary" style="width: 100%; text-align: center; display: block;">Anmelden um zu bestellen</a>
            <% } %>
            <p style="text-align: center; margin-top: 16px; font-size: 13px; color: var(--c-muted);">
                Sichere Zahlung via Stripe &bull; Kreditkarte
            </p>
        </div>
    <% } %>
</main>

<%- include('partials/footer') %>
</body>
</html>
