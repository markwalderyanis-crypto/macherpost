<!DOCTYPE html>
<html lang="de">
<head>
    <%- include('partials/head') %>
    <title>Archiv — MacherPost</title>
</head>
<body>
<%- include('partials/nav') %>

<main class="content" style="max-width: var(--max-w);">
    <h1>Archiv</h1>
    <p style="color: var(--c-muted); margin-bottom: 40px;">W&auml;hle ein Thema, um die Beitr&auml;ge zu lesen.</p>

    <div class="grid-3">
        <% for (const theme of themes) { %>
            <% const hasAccess = userThemes.has(theme.slug); %>
            <a href="/archiv/<%= theme.slug %>" class="card" style="text-decoration: none; transition: all 0.2s; <%= !hasAccess ? 'opacity: 0.6;' : '' %>">
                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
                    <h3 style="font-size: 16px; font-weight: 700; color: var(--c-dark);"><%= theme.name %></h3>
                    <% if (!hasAccess) { %>
                        <span style="font-size: 18px;" class="lock-icon">&#128274;</span>
                    <% } else { %>
                        <span style="font-size: 18px;">&#9989;</span>
                    <% } %>
                </div>
                <p style="font-size: 13px; color: var(--c-muted); margin: 0;">
                    <%= pdfCounts[theme.slug] || 0 %> Beitr&auml;ge
                </p>
            </a>
        <% } %>
    </div>

    <div style="margin-top: 48px; padding: 32px; background: var(--c-accent-light); border-radius: var(--radius); text-align: center;">
        <h2 style="margin: 0 0 12px;">Mehr Themen freischalten?</h2>
        <p style="color: var(--c-muted); margin-bottom: 20px;">Entdecke unsere Pakete und erhalte Zugang zu mehreren Themen gleichzeitig.</p>
        <a href="/pakete/komplett.html" class="btn btn-primary">Pakete entdecken</a>
    </div>
</main>

<%- include('partials/footer') %>
</body>
</html>
